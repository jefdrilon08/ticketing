.card
  .card-header.bg-dark.text-white
    %h4.mb-0 Item Distribution Details

  .card-body
    %form{ id: "itemDistForm", action: item_distribution_path(@item_distribution), method: "post" }
      = hidden_field_tag :authenticity_token, form_authenticity_token
      = hidden_field_tag :_method, "patch"
      .container-fluid
        .row
          .col-md-6
            .row.mb-3
              .col-sm-4
                %label{ for: "distribute_number" } Distribute Number
              .col-sm-8
                %input.form-control{
                  type: "text",
                  id: "distribute_number",
                  name: "item_distribution[distribute_number]",
                  value: @item_distribution.data&.dig("distribute_number") || "",
                  disabled: true
                }
            .row.mb-3
              .col-sm-4
                %label{ for: "category" } Item Category
              .col-sm-8
                %input.form-control{ type: "text", id: "category", value: @item&.items_category&.name&.to_s&.titleize || "N/A", disabled: true }
            .row.mb-3
              .col-sm-4
                %label{ for: "item_name" } Item Name
              .col-sm-8
                %input.form-control{ type: "text", id: "item_name", value: @item&.name || "N/A", disabled: true }
            .row.mb-3
              .col-sm-4
                %label{ for: "distribute_name" } Distribute Name
              .col-sm-8
                %input.form-control{type: "text", id: "distribute_name", name: "item_distribution[distribute_name]", value: @item_distribution.distribute_name, disabled: true}
            .row.mb-3
              .col-sm-4
                %label{ for: "serial_number" } Serial Number
              .col-sm-8
                %input.form-control{type: "text",  id: "serial_number", value: @item&.serial_number || "N/A", disabled: true}
            .row.mb-3
              .col-sm-4
                %label{ for: "mr_number" } MR Number
              .col-sm-8
                %input.form-control{ type: "text", id: "mr_number", name: "item_distribution[mr_number]", value: @item_distribution.mr_number, disabled: true }

            .row.mb-3
              .col-sm-4
                %label{ for: "inventory_number" } Inventory Number
              .col-sm-8
                %input.form-control{ type: "text", id: "inventory_number", name: "item_distribution[inventory_number]", value: @item_distribution.inventory_number, disabled: true }

            .row.mb-3
              .col-sm-8
                .form-check
                  %input.form-check-input{
                    type: "checkbox",
                    id: "attached_mr_sticker",
                    name: "item_distribution[attached_mr_sticker]",
                    value: "true",
                    disabled: true,
                    checked: @item_distribution.data && @item_distribution.data["is_sticker_attached"].to_s == "true"
                  }
                  %label.form-check-label{ for: "attached_mr_sticker" } Attached MR Sticker?

          .col-md-6
            .row.mb-3
              .col-sm-4
                %label{ for: "receive_by" } Received By
              .col-sm-8
                %select.form-control{ id: "receive_by", name: "item_distribution[receive_by]", disabled: true }
                  %option{ value: "" } --SELECT--
                  - @users.values.sort_by { |u| "#{u.first_name} #{u.last_name}".to_s.downcase }.each do |user|
                    - name = "#{user.first_name} #{user.last_name}".strip.presence || user.username || user.email
                    %option{ value: user.id, selected: (@item_distribution.receive_by.to_s == user.id.to_s) }= name.titleize

            .row.mb-3
              .col-sm-4
                %label{ for: "distributed_by" } Distributed By
              .col-sm-8
                %select.form-control{ id: "distributed_by", name: "item_distribution[distributed_by]", disabled: true }
                  %option{ value: "" } --SELECT--
                  - @distributors.sort_by { |u| "#{u.first_name} #{u.last_name}".to_s.downcase }.each do |user|
                    - name = "#{user.first_name} #{user.last_name}".strip.presence || user.username || user.email
                    %option{ value: user.id, selected: (@item_distribution.distributed_by.to_s == user.id.to_s) }= name.titleize

            .row.mb-3
              .col-sm-4
                %label{ for: "distributed_at" } Distributed At
              .col-sm-8
                %input.form-control{ type: "date", id: "distributed_at", name: "item_distribution[distributed_at]", value: @item_distribution.distributed_at&.strftime("%Y-%m-%d"), disabled: true }

            .row.mb-3
              .col-sm-4
                %label{ for: "status" } Status
              .col-sm-8
                %input.form-control{ type: "text", id: "status", name: "item_distribution[status]", value: @item_distribution.status&.titleize || "-", disabled: true }

            .row.mb-3
              .col-sm-4
                %label{ for: "area_id" } Area
              .col-sm-8
                %select.form-control{ id: "area_id", name: "item_distribution[area_id]", disabled: true }
                  %option{ value: "" } --SELECT--
                  - @areas.values.sort_by { |a| a.name.to_s.downcase }.each do |area|
                    %option{ value: area.id, selected: (@item_distribution.area_id.to_s == area.id.to_s) }= area.name.titleize

            .row.mb-3
              .col-sm-4
                %label{ for: "cluster_id" } Cluster
              .col-sm-8
                %select.form-control{ id: "cluster_id", name: "item_distribution[cluster_id]", disabled: true }
                  %option{ value: "" } --SELECT--
                  - @clusters.values.sort_by { |c| c.name.to_s.downcase }.each do |cluster|
                    %option{ value: cluster.id, selected: (@item_distribution.cluster_id.to_s == cluster.id.to_s), data: { area_id: cluster.area_id } }= cluster.name.titleize

            .row.mb-3
              .col-sm-4
                %label{ for: "branch_id" } Branch
              .col-sm-8
                %select.form-control{ id: "branch_id", name: "item_distribution[branch_id]", disabled: true }
                  %option{ value: "" } --SELECT--
                  - @branches.values.sort_by { |b| b.name.to_s.downcase }.each do |branch|
                    %option{ value: branch.id, selected: (@item_distribution.branch_id.to_s == branch.id.to_s), data: { cluster_id: branch.cluster_id } }= branch.name.titleize

    - if @item&.data && @item.data["child_details"].present?
      .card.mt-3
        .card-header.bg-dark.text-white
          %h5.mb-0 Child Item Details
        .card-body
          .table-responsive
            %table.table.table-bordered.table-striped.table-hover
              %thead.table-light
                %tr
                  %th Item Name
                  %th Category
                  %th Sub Category
                  %th Brand
                  %th Model
                  %th Serial Number
                  %th Unit
                  -# %th Unit Price
              %tbody
                - @item.data["child_details"].each do |child|
                  %tr
                    %td= child["name"] || "-"
                    %td= child["item_category"] || "-"
                    %td= child["sub_category"] || "-"
                    %td= child["brand"] || "-"
                    %td= child["model"] || "-"
                    %td= child["serial_number"] || "-"
                    %td= child["unit"] || "-"
                    -# %td= "₱ #{number_with_precision(child["unit_price"].to_f, precision: 2)}" || "-"
    - if @item_distribution.data && @item_distribution.data["transfer_details"].present?
      .card.mt-3
        .card-header.bg-dark.text-white
          %h5.mb-0 Transfer History
        .card-body
          .table-responsive
            %table.table.table-bordered.table-striped.table-hover
              %thead
                %tr
                  %th Previous User
                  -# %th Previous Area
                  -# %th Previous Cluster
                  %th Previous Branch
                  %th Transfer Date
              %tbody
                - @item_distribution.data["transfer_details"].each do |transfer|
                  %tr
                    %td= transfer["previous_distribute_name"] || "N/A"
                    -# %td= transfer["previous_area"] || "N/A"
                    -# %td= transfer["previous_cluster"] || "N/A"
                    %td= transfer["previous_branch"] || "N/A"
                    %td= transfer["transfer_date"] || "N/A"
    - else
      .card-footer
        .mt-2
          %p.text-muted &nbsp;

    .row.mt-3
      .col-12.d-flex.justify-content-end.align-items-center
        %button.btn.btn-primary.me-2.mb-2#editBtn{ type: "button", onclick: "enableEdit()" } Edit
        %button.btn.btn-success.me-2.mb-2#saveBtn{ type: "submit", form: "itemDistForm", style: "display:none" } Save
        %button.btn.btn-secondary.fs-6.me-2.mb-2{ type: "button", onclick: "window.history.back();" } Back

= render "item_distributions/modals/transfer_item_distribution"
= render "item_distributions/modals/pull_out"

:javascript
  function enableEdit() {
    var form = document.getElementById('itemDistForm');
    Array.from(form.elements).forEach(function(el) {
      if (
        el.type !== "hidden" &&
        el.name !== "authenticity_token" &&
        el.id !== "item_name" &&
        el.id !== "category" &&
        el.id !== "status" &&
        el.id !== "serial_number"
      ) {
        el.disabled = false;
      }
    });
    document.getElementById('editBtn').style.display = 'none';
    document.getElementById('saveBtn').style.display = '';
    setupDependentSelects();
  }

  function setupDependentSelects() {
    const areaSelect = document.getElementById('area_id');
    const clusterSelect = document.getElementById('cluster_id');
    const branchSelect = document.getElementById('branch_id');
    const originalClusterId = clusterSelect.value;
    const originalBranchId = branchSelect.value;

    areaSelect.removeEventListener('change', handleAreaChange);
    clusterSelect.removeEventListener('change', handleClusterChange);

    function handleAreaChange() {
      const selectedAreaId = areaSelect.value;
      Array.from(clusterSelect.options).forEach(function(option) {
        if (option.value === "") {
          option.style.display = "block";
        } else {
          option.style.display = option.dataset.areaId === selectedAreaId ? "block" : "none";
        }
      });

      if (originalClusterId && document.querySelector(`#cluster_id option[value="${originalClusterId}"]`)) {
        const originalOption = document.querySelector(`#cluster_id option[value="${originalClusterId}"]`);
        if (originalOption.dataset.areaId === selectedAreaId) {
          clusterSelect.value = originalClusterId;
          clusterSelect.dispatchEvent(new Event('change'));
        } else {
          clusterSelect.value = "";
          branchSelect.value = "";
        }
      } else {
        clusterSelect.value = "";
        branchSelect.value = "";
      }
    }

    function handleClusterChange() {
      const selectedClusterId = clusterSelect.value;
      Array.from(branchSelect.options).forEach(function(option) {
        if (option.value === "") {
          option.style.display = "block";
        } else {
          option.style.display = option.dataset.clusterId === selectedClusterId ? "block" : "none";
        }
      });

      if (originalBranchId && document.querySelector(`#branch_id option[value="${originalBranchId}"]`)) {
        const originalOption = document.querySelector(`#branch_id option[value="${originalBranchId}"]`);
        if (originalOption.dataset.clusterId === selectedClusterId) {
          branchSelect.value = originalBranchId;
        } else {
          branchSelect.value = "";
        }
      } else {
        branchSelect.value = "";
      }
    }

    areaSelect.addEventListener('change', handleAreaChange);
    clusterSelect.addEventListener('change', handleClusterChange);

    if (areaSelect.value) {
      handleAreaChange();
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    setupDependentSelects();
  });