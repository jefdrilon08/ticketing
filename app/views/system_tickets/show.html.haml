:javascript
    var idAll=''
    var cbArray=[]
    var new_cbArray=[]

    onload=checkboxes(document.getElementById("req-length").value);

    function checkboxes(n)
    {
        console.log("pumasok")
        console.log(n)
        var i=0

        while(n>i)
        {
            console.log(document.getElementById("cb-"+(i+1)).value)

            if(document.getElementById("cb-"+(i+1)).value=="true")
                document.getElementById("cb-"+(i+1)).checked=true
            else 
                document.getElementById("cb-"+(i+1)).checked=false

            cbArray.push(String(document.getElementById("cb-"+(i+1)).checked))
            new_cbArray.push(String(document.getElementById("cb-"+(i+1)).checked))
            i++
        }

        document.getElementById("edit-req-stat").style.display="none"
    }

    function checkboxUpdate(n,v)
    {
        console.log
        new_cbArray[n-1]=v

        if(JSON.stringify(new_cbArray)==JSON.stringify(cbArray))
        {
            document.getElementById("edit-req-stat").style.display="none"
        }
        else
        {
            document.getElementById("edit-req-stat").style.display="block"
        }
    }

    function checkboxVal(n,b)
    {
        console.log(n);
        console.log(b==String(document.getElementById("cb-"+n).checked))

        checkboxUpdate(n,String(document.getElementById("cb-"+n).checked))
    } 

    function submitNewCheck()
    {

        var checked=document.getElementById('cbChecked')
        var unchecked=document.getElementById('cbUnchecked')

        checked.innerHTML=""
        unchecked.innerHTML=""


        let checked2=0

        document.getElementById("newCheck").value=new_cbArray

        for(i=0;new_cbArray.length>i;i++)
        {
            let li = document.createElement('li')
                li.innerText=document.getElementById("cb-item-"+(i+1)).value
            
            if(new_cbArray[i]=="true")
            {
                checked.appendChild(li)
                checked2++
            }
            else
            {
                unchecked.appendChild(li)
            }
        }

        console.log(unchecked.length==0)

        if(checked2==new_cbArray.length)
        {
            document.getElementById("allChecked").style.display="block"
            document.getElementById("allCheckedNot").style.display="none"
            document.getElementById("allUnchecked").style.display="none"
        }
        if(checked2!=new_cbArray.length&&checked2>0)
        {
            document.getElementById("allCheckedNot").style.display="block"
            document.getElementById("allChecked").style.display="none"
            document.getElementById("allUnchecked").style.display="none"
        }
        if(checked2==0)
        {
            document.getElementById("allCheckedNot").style.display="none"
            document.getElementById("allChecked").style.display="none"
            document.getElementById("allUnchecked").style.display="block"
        }
    }

