-@milestone1=0
%p
.card.some{:style=>"padding:1%"}
    #react-root
    %div.row{:style=>"width:100%"}
        %div
            %table.table.table-bordered{:style=>"font-size:115%;margin-bottom:0px"}
                %tr
                    %th{:style=>"width:10%"}
                        %h
                            Ticket no. 
                    %td
                        %d
                            #{@ticket.ticket_number}
                %tr
                    %th
                        %h
                            Subject
                    %td
                        %d
                            #{@ticket.title}
        %center
            %hr{:style=>"height:0px"}
        %div.col-3
            %table.table.table-bordered.table-sm{:style=>"margin-bottom:0px"}   
                %tr
                    %th{:style=>"width:50%"}
                        %p 
                            System name:
                    %td{:style=>"width:50%"}
                        %p
                            #{ComputerSystem.find(SystemTicket.find(@ticket.system_ticket_id).computer_system_id).name}
                %tr
                    %th
                        %p 
                            Request type:
                    %td
                        %p
                            #{@ticket.request_type}
                %tr
                    %th
                        %p{:style=>"margin-top:10%"}
                            Status:
                            -if !@ticket.data["on_hold"]
                                - case @ticket.status
                                - when "processing"
                                    %td
                                        %center
                                            %p{:style=>";width:104px"}
                                                .badge.bg-primary
                                                    #{@ticket.status}
                                    %td
                                - when "checked"
                                    %td
                                        %center
                                            %p{:style=>";width:104px"}
                                                .badge.bg-success
                                                    #{@ticket.status} 
                                    %td
                                - when "approved"
                                    %td
                                        %center
                                            %p{:style=>";width:104px"}
                                                .badge.bg-success
                                                    #{@ticket.status} 
                                - when "pending"
                                    %td
                                        %center
                                            %p{:style=>"width:104px"}
                                                .badge.bg-warning
                                                    #{@ticket.status} 
                                - when "for verification"
                                    %td
                                        %center
                                            %p{:style=>"width:104px"}
                                                .badge.bg-secondary
                                                    #{@ticket.status} 
                                - when "for testing"
                                    %td
                                        %center
                                            %p{:style=>"width:104px"}
                                                .badge.bg-primary
                                                    #{@ticket.status} 
                                -else
                                    %td
                                        %center
                                            %p{:style=>"width:104px"}
                                                .badge.bg-dark
                                                    #{@ticket.status}
                            -else
                                %td
                                    %center
                                        %p{:style=>"width:104px"}
                                            .badge.bg-danger
                                                on hold
                %tr
                    %td
                        %p{:style=>"margin-top:10%;margin-bottom:-1%;font-weight:bold"}
                            Category:&nbsp&nbsp
                            -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                -if @role==3 || @role==5
                                    %span{:style=>"font-weight:normal"}
                                        =link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-change-category" },id:'btn-new-milestone' do
                                            Edit
                    %td
                        %p
                            - if @ticket.data.include? "category"
                                - case @ticket.data["category"]
                                - when "high"
                                    %center
                                        %p{:style=>";width:104px"}
                                            .badge.bg-danger
                                                high
                                - when "medium"
                                    %center
                                        %p{:style=>";width:104px"}
                                            .badge.bg-warning
                                                medium
                                - when "low" 
                                    %center
                                        %p{:style=>";width:104px"}
                                            .badge.bg-success
                                                low
                            - else
                                %center
                                    %p{:style=>";width:104px"}
                                        .badge.bg-secondary
                                            uncatergorized
                %tr
                    %th
                        %p
                            Date received:
                    %td
                        %p
                            #{@ticket.date_received}
                %tr
                    %th
                        %p
                            Date started:
                    %td
                        - case @ticket.start_date
                        - when nil
                            -if @role==3 || @role==5
                                -if !@ticket.data["on_hold"]
                                    =link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-set-start-date" },id:'btn-new-milestone' do
                                        %p
                                            Set start date
                            -else
                                %p
                                    Not yet set. 
                        - else
                            %p
                                #{@ticket.start_date}
                %tr
                    %th
                        %p 
                            Requested by:
                    %td
                        %p
                            #{User.find(@ticket.requested_by).last_name}, #{User.find(@ticket.requested_by).first_name}
                %tr
                    %th
                        %p 
                            Target date:
                    %td
                        %p
                            #{@ticket.target_date}&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp
                            -if !@ticket.data["on_hold"] && @ticket.status=="pending"
                                -if @role==3 || @role==5
                                    %span
                                        =link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-target-date" },id:'btn-new-milestone' do
                                            Edit
            %hr{:style=>"width:100%"}
            %table.table.table-bordered.table-sm
                %tr
                    %th{:style=>"width:25%"}
                        %p
                            Main Dev:
                    %td
                        %p
                            -case @maindev
                                -when ""
                                    Not assigned
                                -else
                                    #{@maindev[0]}
                    %td{:style=>"width:20%"}
                        -if @ticket.status!="done" && @ticket.status!="auto-closed"
                            -if @role==3 || @role==5
                                = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-main-dev" },id:"btn-milestone" do
                                    Change
                -i_show=0
                -@mem_list.each do |x|
                    %tr
                        %th
                            -if i_show==0
                                %p
                                    Members:
                            -else
                                %p
                        %td
                            %p
                                #{x[0]} 
                                %span{:style=>"color:gray"} - #{x[1]}
                        %td
                            -if i_show==0
                                -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                    -if @role==3 || @role==5
                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-members" },id:"btn-milestone" do
                                            Edit
                            -else
                    -i_show+=1
                -if @mem_list.empty?
                    %tr
                        %th
                            %p
                                Members:
                        %td
                            %p
                                No members
                        %td
                            -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                -if @role==3 || @role==5
                                    = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-members" },id:"btn-milestone" do
                                        Edit

            %hr{:style=>"width:100%"}
            %table.table.table-bordered.table-sm
                %tr
                    %th{:style=>"width:25%"}
                        %p
                            Attached File(s):
                    -if !@ticket.data["file"].empty? && current_user.id==@ticket.requested_by
                        %td{:style=>"width:5%"}
                -if !@ticket.file.attached?
                    -if current_user.id==@ticket.requested_by
                        %td
                            = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-add-attachment" },id:'btn-new-milestone' do
                                Add attachment       
                    -else 
                        %td
                            No attachment found.     
                -else 
                    -file_count=0
                    -while file_count!=@ticket.data["file"].count
                        %tr
                            %td
                                %a{:href=>url_for(@ticket.file[@ticket.file.count-@ticket.data["file"].count]),:download=>"download"}
                                    #{@ticket.data["file"][file_count]["original_filename"]}
                                -file_count=file_count+1
                                -if file_count==1 && current_user.id==@ticket.requested_by
                                    %td{:style=>"width:5%"}
                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-add-attachment" },id:'btn-new-milestone' do
                                            Edit
                                -else

        %div.col-9
            %table.table.table-bordered.table-sm{:style=>"margin-top:15px;margin-bottom:0px"}  
                %tr
                    %th{:style=>"width:10%"}
                        %p 
                            Description:
                    %td
                        %p{:style=>"min-height:40px"}
                            #{@ticket.description}
                %tr
                    %th{:style=>"width:10%"}
                        %p 
                            Request Impact:
                        %p{:style=>"font-weight:200"}
                            (How will this request impact the system?)
                    %td
                        -if @ticket.data["impact"].present?
                            %p{:style=>"min-height:40px"}
                                #{@ticket.data["impact"]}
                        -else
                            %p{:style=>"min-height:40px"}
                                No data.
            %hr
            %div.row
                -if SystemTicket.find(@ticket.system_ticket_id).data["testing_required"]
                    %div.col-4
                        .card.some{:style=>"padding:2%;"}
                            %table.table{:style=>"border-color:white;font-size:115%;margin-bottom:0px"}
                                %tr
                                    %td{:style=>"width:15%"}
                                        %h3
                                            Requirements
                                    %td{:style=>"padding-top:12px"}
                                        -if !@ticket.data["on_hold"]
                                            -if @ticket.status!="done" && @ticket.status!="auto-closed" && @ticket.status!="for verification"
                                                -if @role==3 || @role==5|| @role==2
                                                    = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-new-requirement" },id:'btn-new-requirement' do
                                                        Add requirement  
                                %table.table{:style=>"border-color:white;font-size:115%"} 
                                    %table.table.table-bordered.table-sm
                                        %tr
                                            %th{:style=>"width:10%"}
                                                %p
                                            %th{:style=>"width:70%"}
                                                %p
                                                    %center
                                                        Details
                                            %th{:style=>"width:10%"}
                                                %p
                                                    %center
                                                        Action
                                            %th{:style=>"width:10%"}
                                                %p
                                            -@requirements.each.with_index(1) do |x,i|
                                                %tr
                                                    %td
                                                        %p
                                                            %center
                                                                #{i}
                                                    %td
                                                        %p
                                                            %center
                                                                =text_field_tag :temp,x[0],class:'form-control',id:"cb-item-#{i}",value:x[0],style:"display:none"
                                                                #{x[0]}
                                                    %td
                                                        -if @role==6||@ticket.requested_by==current_user.id
                                                            %p
                                                                %center
                                                                    =text_field_tag :temp,x[0],class:'form-control',id:"req-#{i-1}",value:x[0],style:"display:none"
                                                                    = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-requirement-details"}, onclick:"reqId(#{i-1})" do
                                                                        Edit
                                                    %td
                                                        -if @ticket.status=="for testing" 
                                                            -if@role==6||@ticket.requested_by==current_user.id
                                                                %p
                                                                    %center
                                                                        =check_box_tag "a", value:x[1], id:"cb-#{i}", onclick:"checkboxVal(#{i},value)"
                                                        -else
                                                            %p
                                                                %center
                                                                    =check_box_tag "a", value:x[1], id:"cb-#{i}", onclick:"checkboxVal(#{i},value)", disabled:"disabled"
                                    .form-group
                                        =text_field_tag :temp,"a",class:'form-control', id:"req-length",value:@requirements.count,style:"display:none"
                                        %div{:id=>"edit-req-stat"}
                                            %right 
                                                =link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-change-checklist" },id:'btn-new-milestone' do
                                                    =button_tag type: 'submit', class: 'btn btn-primary', onclick:"submitNewCheck()" do
                                                        Save
                                    -if @requirements==[]
                                        %center
                                            %hr{:style=>"height:30px;color:white"}
                                            %h4
                                                No requirement found.
                                            %hr{:style=>"height:30px;color:white"}
                -if SystemTicket.find(@ticket.system_ticket_id).data["testing_required"]            
                    %div.col-8
                        .card.some{:style=>"padding:1%;"}
                            %table.table{:style=>"border-color:white;font-size:115%;margin-bottom:0px"}
                                %tr
                                    %td{:style=>"width:15%"}
                                        %h3
                                            Milestones
                                    %td{:style=>"padding-top:12px"}
                                        -if !@ticket.data["on_hold"]
                                            -if @ticket.status!="done" && @ticket.status!="auto-closed" && @ticket.status!="for verification"
                                                -if @role==3 || @role==5|| @role==2
                                                    = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-new-milestone" },id:'btn-new-milestone' do
                                                        Add milestone    
                                
                            %table.table{:style=>"border-color:white;font-size:115%"}
                                %table.table.table-bordered.table-sm
                                    %tr
                                        %th{:style=>"width:30%"}
                                            %p
                                                %center
                                                    Details
                                        %th{:style=>"width:5%"}
                                            %p
                                                %center
                                                    Status
                                        %th{:style=>"width:10%"}
                                            %p
                                                %center
                                                    Target Date
                                        %th{:style=>"width:10%"}
                                            %p
                                                %center
                                                    Start Date
                                        %th{:style=>"width:10%"}
                                            %p
                                                %center
                                                    End Date
                                        %th{:style=>"width:10%"}
                                            %p
                                                %center
                                                    Assigned Dev
                                        %th{:style=>"width:5%"}
                                            %p
                                                %center
                                                    Action
                                    - if !@empty
                                        - @milestones.each do |x|
                                            -if x.start_date==nil
                                                %tr
                                                    %td
                                                        %p
                                                            %center
                                                                .form-group
                                                                    =text_field_tag :ms_id,x.id,class:'form-control',id:"m-#{@milestones.index(x)}",style:'display:none'
                                                                %p{:id=>"d-#{@milestones.index(x)}"}
                                                                    #{x.milestone_details}&nbsp
                                                                - case x.status
                                                                    - when 'pending'
                                                                        -if !@ticket.data["on_hold"]
                                                                            -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                                                                -if @role==3 || @role==5 
                                                                                    %p{:style=>"margin-top:-15px"}
                                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-details"},onclick:"putMSId2(#{@milestones.index(x)});return false" do
                                                                                            Edit
                                                                                -if @role==2 && SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id).count>0 && x.assigned_person==SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id)[0].id
                                                                                    %p{:style=>"margin-top:-15px"}
                                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-details"},onclick:"putMSId2(#{@milestones.index(x)});return false" do
                                                                                            Edit
                                                    %td
                                                        %p
                                                            %center
                                                                - case x.status
                                                                - when 'pending'
                                                                    .badge.bg-warning
                                                                        #{x.status}
                                                                - when 'done'
                                                                - when 'auto-closed'
                                                                    .badge.bg-dark
                                                                        #{x.status}
                                                    %td
                                                        %p
                                                            %center
                                                                #{x.target_date}
                                                        %p 
                                                            %center
                                                                =text_field_tag :temp,x.id,class:'form-control',id:"t-#{@milestones.index(x)}",style:'display:none'
                                                                =text_field_tag :temp,x.id,class:'form-control',id:"date-#{@milestones.index(x)}",value:"#{x.target_date}",style:"display:none"
                                                                =text_field_tag :temp,x.assigned_person,class:'form-control',id:"dev-#{@milestones.index(x)}",value:"#{User.find(SystemTicketsUser.find(x.assigned_person).user_id).last_name}, #{User.find(SystemTicketsUser.find(x.assigned_person).user_id).first_name}",style:"display:none"
                                                                =text_field_tag :temp,x.assigned_person,class:'form-control',id:"devid-#{@milestones.index(x)}",value:"#{x.assigned_person}",style:"display:none"
                                                                - case x.status
                                                                    - when 'pending'
                                                                        -if !@ticket.data["on_hold"]
                                                                            -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                                                                -if @role==3 || @role==5
                                                                                    %p{:style=>"margin-top:-15px"}
                                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-target-date"},onclick:"putMSId3(#{@milestones.index(x)});return false" do
                                                                                            Edit
                                                                                -if @role==2 && SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id).count>0 && x.assigned_person==SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id)[0].id
                                                                                    %p{:style=>"margin-top:-15px"}
                                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-target-date"},onclick:"putMSId3(#{@milestones.index(x)});return false" do
                                                                                            Edit
                                                    %td
                                                        -if @role==3 || @role==5
                                                            %p
                                                                %center
                                                                    = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-set-start-date-milestone"},onclick:"putMSId(#{@milestones.index(x)});return false" do
                                                                        Set date
                                                        -elsif @role==2 && SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id).count>0 && x.assigned_person==SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id)[0].id
                                                            %p
                                                                %center
                                                                    = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-set-start-date-milestone"},onclick:"putMSId(#{@milestones.index(x)});return false" do
                                                                        Set date
                                                        -else
                                                            %p 
                                                                %center 
                                                                    #{"--"}
                                                    %td
                                                        %p
                                                            %center
                                                                #{"--"}
                                                    %td
                                                        %p
                                                            %center
                                                                #{User.find(SystemTicketsUser.find(x.assigned_person).user_id).last_name}, #{User.find(SystemTicketsUser.find(x.assigned_person).user_id).first_name}
                                                                -if @role==3 || @role==5 && @ticket.status!="done" && x.status=="pending"
                                                                    %p
                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-assigned"},onclick:"putMSId4(#{@milestones.index(x)});return false" do
                                                                            Edit
                                                    %td
                                                        %p
                                            -else
                                                %tr
                                                    = form_tag "edit_milestone", method: 'POST' do
                                                        %td
                                                            %p
                                                                %center
                                                                    .form-group
                                                                        =text_field_tag :temp,x.id,class:'form-control',id:"m-#{@milestones.index(x)}",style:'display:none'
                                                                    .form-group
                                                                        =text_field_tag :temp,x.id,class:'form-control',id:"u-#{@milestones.index(x)}",style:'display:none'
                                                                    %p{:id=>"d-#{@milestones.index(x)}"}
                                                                        #{x.milestone_details}&nbsp
                                                                    - case x.status
                                                                        - when 'pending'
                                                                            -if !@ticket.data["on_hold"]
                                                                                -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                                                                    -if @role==3 || @role==5
                                                                                        %p{:style=>"margin-top:-15px"}
                                                                                            = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-details"},onclick:"putMSId2(#{@milestones.index(x)});return false" do
                                                                                                Edit
                                                                                    -if @role==2 && SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id).count>0 && x.assigned_person==SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id)[0].id
                                                                                        %p{:style=>"margin-top:-15px"}
                                                                                            = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-details"},onclick:"putMSId2(#{@milestones.index(x)});return false" do
                                                                                                Edit
                                                        %td
                                                            %p
                                                                %center
                                                                    - case x.status
                                                                    - when 'pending'
                                                                        .badge.bg-warning
                                                                            #{x.status}
                                                                    - when 'done'
                                                                        .badge.bg-dark
                                                                            #{x.status}
                                                        %td
                                                            %p
                                                                %center
                                                                    #{x.target_date}
                                                            %p 
                                                            %center
                                                                =text_field_tag :temp,x.id,class:'form-control',id:"t-#{@milestones.index(x)}",style:'display:none'
                                                                =text_field_tag :temp,x.id,class:'form-control',id:"date-#{@milestones.index(x)}",value:"#{x.target_date}",style:"display:none"
                                                                =text_field_tag :temp,x.assigned_person,class:'form-control',id:"dev-#{@milestones.index(x)}",value:"#{User.find(SystemTicketsUser.find(x.assigned_person).user_id).last_name}, #{User.find(SystemTicketsUser.find(x.assigned_person).user_id).first_name}",style:"display:none"
                                                                =text_field_tag :temp,x.assigned_person,class:'form-control',id:"devid-#{@milestones.index(x)}",value:"#{x.assigned_person}",style:"display:none"
                                                                - case x.status
                                                                    - when 'pending'
                                                                        -if !@ticket.data["on_hold"]
                                                                            -if @ticket.status!="done" && @ticket.status!="auto-closed"
                                                                                -if @role==3 || @role==5
                                                                                    %p{:style=>"margin-top:-15px"}
                                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-target-date"},onclick:"putMSId3(#{@milestones.index(x)});return false" do
                                                                                            Edit
                                                                                -if @role==2 && SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id).count>0 && x.assigned_person==SystemTicketsUser.where(user_id:current_user.id,system_ticket_id:@ticket.system_ticket_id)[0].id
                                                                                    %p{:style=>"margin-top:-15px"}
                                                                                        = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-target-date"},onclick:"putMSId3(#{@milestones.index(x)});return false" do
                                                                                            Edit
                                                        %td
                                                            %p
                                                                %center
                                                                    #{x.start_date}
                                                        %td
                                                            %p
                                                                %center
                                                                    -if x.end_date==nil
                                                                        #{"--"}
                                                                    -else
                                                                        #{x.end_date}
                                                        %td
                                                            %p
                                                                %center
                                                                    #{User.find(SystemTicketsUser.find(x.assigned_person).user_id).last_name}, #{User.find(SystemTicketsUser.find(x.assigned_person).user_id).first_name}
                                                                    -if @role==3 || @role==5 && @ticket.status!="done" && x.status=="pending"
                                                                        %p
                                                                            = link_to "#", data: { "bs-toggle": "modal", "bs-target": "#modal-edit-milestone-assigned"},onclick:"putMSId4(#{@milestones.index(x)});return false" do
                                                                                Edit
                                                        %td
                                                            %p
                                                                %center
                                                                    - case x.status
                                                                        - when 'pending'
                                                                            .form-group
